        <div class="pagination" id="paginacion" style="display:none;">
          <span class="pagination-info" id="paginacionInfo"></span>
          <div class="pagination-btns" id="paginacionBtns"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- MODAL DETALLE -->
<div class="modal-overlay" id="modalDetalle">
  <div class="modal-detalle">
    <div class="modal-top">
      <div>
        <h3 id="modalTitulo">Cotización #</h3>
        <span id="modalSubtitulo"></span>
      </div>
      <button class="modal-close-btn" onclick="cerrarModal()">✕</button>
    </div>
    <div class="modal-body">
      <div class="detalle-grid" id="detalleGrid"></div>
      <div class="detalle-section-title">Artículos de la cotización</div>
      <div style="overflow-x:auto;">
        <table class="articulos-table" id="articulosTable">
          <thead>
            <tr>
              <th>Código</th>
              <th>Artículo</th>
              <th>Cant.</th>
              <th>Moneda</th>
              <th>V. Unitario</th>
              <th>Descuento</th>
              <th>V. Venta</th>
              <th>Estado</th>
            </tr>
          </thead>
          <tbody id="articulosBody"></tbody>
        </table>
      </div>
      <div class="total-row" id="totalRow"></div>
    </div>
  </div>
</div>

<script>
  const API = "https://threer-api.onrender.com/api/cotizaciones";
  let todasLasCotizaciones = [];
  let cotizacionesFiltradas = [];
  let paginaActual = 1;
  const POR_PAGINA = 50;

  // Verificar sesión
  const usuario = localStorage.getItem("usuario");
  if (!usuario) window.location.href = "index.html";

  // Fecha
  const dias = ["domingo","lunes","martes","miércoles","jueves","viernes","sábado"];
  const meses = ["enero","febrero","marzo","abril","mayo","junio","julio","agosto","septiembre","octubre","noviembre","diciembre"];
  const hoy = new Date();
  document.getElementById("topbarFecha").innerText = `Hoy es ${dias[hoy.getDay()]}, ${hoy.getDate()} de ${meses[hoy.getMonth()]} ${hoy.getFullYear()}`;

  // Cargar datos al iniciar
  async function cargarDatos() {
    mostrarCargando();
    try {
      const res = await fetch(API);
      todasLasCotizaciones = await res.json();
    } catch (e) {
      mostrarError("No se pudo conectar con la API. Verifica tu conexión.");
    }
  }

  function mostrarCargando() {
    document.getElementById("tablaBody").innerHTML = `
      <tr><td colspan="12">
        <div class="loading-state">
          <div class="loading-spinner"></div>
          <p>Cargando cotizaciones...</p>
        </div>
      </td></tr>`;
  }

  function mostrarError(msg) {
    document.getElementById("tablaBody").innerHTML = `
      <tr><td colspan="12">
        <div class="empty-state">
          <div class="empty-icon">⚠️</div>
          <h4>Error</h4>
          <p>${msg}</p>
        </div>
      </td></tr>`;
  }

  function buscar() {
    const filtroCot = document.getElementById("filtroCot").value.trim().toLowerCase();
    const filtroCliente = document.getElementById("filtroCliente").value.trim().toLowerCase();
    const filtroArticulo = document.getElementById("filtroArticulo").value.trim().toLowerCase();

    if (!filtroCot && !filtroCliente && !filtroArticulo) {
      alert("Ingresa al menos un criterio de búsqueda.");
      return;
    }

    cotizacionesFiltradas = todasLasCotizaciones.filter(c => {
      const matchCot = !filtroCot || (c.NumeroCotizacion || "").toLowerCase().includes(filtroCot);
      const matchCliente = !filtroCliente || (c.Cliente || "").toLowerCase().includes(filtroCliente);
      const matchArticulo = !filtroArticulo ||
        (c.Articulo || "").toLowerCase().includes(filtroArticulo) ||
        (c.CodigoArticulo || "").toLowerCase().includes(filtroArticulo);
      return matchCot && matchCliente && matchArticulo;
    });

    paginaActual = 1;
    actualizarStats();
    renderTabla();
  }

  function limpiar() {
    document.getElementById("filtroCot").value = "";
    document.getElementById("filtroCliente").value = "";
    document.getElementById("filtroArticulo").value = "";
    cotizacionesFiltradas = [];
    document.getElementById("statTotal").innerText = "—";
    document.getElementById("statAtendidas").innerText = "—";
    document.getElementById("statValor").innerText = "—";
    document.getElementById("statClientes").innerText = "—";
    document.getElementById("tableCount").innerText = "0 registros";
    document.getElementById("paginacion").style.display = "none";
    document.getElementById("tablaBody").innerHTML = `
      <tr><td colspan="12">
        <div class="loading-state">
          <div class="empty-icon">📋</div>
          <h4>Ingresa un criterio de búsqueda</h4>
          <p>Busca por número de cotización, cliente o artículo</p>
        </div>
      </td></tr>`;
  }

  function actualizarStats() {
    const total = cotizacionesFiltradas.length;
    const atendidas = cotizacionesFiltradas.filter(c => (c.Estado || "").toLowerCase() === "atendido").length;
    const valorTotal = cotizacionesFiltradas.reduce((s, c) => s + (Number(c.ValorVenta) || 0), 0);
    const clientesUnicos = new Set(cotizacionesFiltradas.map(c => c.Cliente)).size;

    document.getElementById("statTotal").innerText = total.toLocaleString();
    document.getElementById("statAtendidas").innerText = atendidas.toLocaleString();
    document.getElementById("statValor").innerText = "$" + valorTotal.toLocaleString("es-PE", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    document.getElementById("statClientes").innerText = clientesUnicos.toLocaleString();
    document.getElementById("tableCount").innerText = `${total.toLocaleString()} registros`;
  }

  function renderTabla() {
    const inicio = (paginaActual - 1) * POR_PAGINA;
    const fin = inicio + POR_PAGINA;
    const pagina = cotizacionesFiltradas.slice(inicio, fin);
    const tbody = document.getElementById("tablaBody");

    if (pagina.length === 0) {
      tbody.innerHTML = `
        <tr><td colspan="12">
          <div class="empty-state">
            <div class="empty-icon">🔍</div>
            <h4>Sin resultados</h4>
            <p>No se encontraron cotizaciones con ese criterio</p>
          </div>
        </td></tr>`;
      document.getElementById("paginacion").style.display = "none";
      return;
    }

    tbody.innerHTML = pagina.map(c => {
      const estado = c.Estado || "";
      let badgeClass = "badge-otro";
      if (estado.toLowerCase() === "atendido") badgeClass = "badge-atendido";
      else if (estado.toLowerCase() === "pendiente") badgeClass = "badge-pendiente";
      else if (estado.toLowerCase() === "perdido") badgeClass = "badge-perdido";

      const valorUnit = Number(c.ValorUnitario) || 0;
      const valorVenta = Number(c.ValorVenta) || 0;
      const descuento = Number(c.PorcentajeDescuento) || 0;
      const moneda = c.Moneda === "Dolares" ? "$" : "€";

      return `<tr onclick="verDetalle(${c.CotizacionId})">
        <td class="mono"><b>${c.NumeroCotizacion || "—"}</b></td>
        <td>${formatFecha(c.FechaCotizacion)}</td>
        <td style="max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${c.Cliente || "—"}</td>
        <td style="max-width:220px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${c.Articulo || "—"}</td>
        <td style="text-align:center;">${c.Cantidad || 1}</td>
        <td>${c.Moneda || "—"}</td>
        <td style="text-align:right;">${moneda}${valorUnit.toLocaleString("es-PE", {minimumFractionDigits:2,maximumFractionDigits:2})}</td>
        <td style="text-align:center;">${descuento > 0 ? descuento + "%" : "—"}</td>
        <td style="text-align:right;font-weight:700;color:#111;">${moneda}${valorVenta.toLocaleString("es-PE", {minimumFractionDigits:2,maximumFractionDigits:2})}</td>
        <td><span class="badge-estado ${badgeClass}">${estado || "—"}</span></td>
        <td style="max-width:140px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-size:11px;color:#888;">${(c.Vendedor || "—").split(",")[0]}</td>
        <td><button class="btn-ver" onclick="event.stopPropagation();verDetalle(${c.CotizacionId})">Ver</button></td>
      </tr>`;
    }).join("");

    renderPaginacion();
  }

  function renderPaginacion() {
    const totalPaginas = Math.ceil(cotizacionesFiltradas.length / POR_PAGINA);
    if (totalPaginas <= 1) {
      document.getElementById("paginacion").style.display = "none";
      return;
    }

    document.getElementById("paginacion").style.display = "flex";
    const inicio = (paginaActual - 1) * POR_PAGINA + 1;
    const fin = Math.min(paginaActual * POR_PAGINA, cotizacionesFiltradas.length);
    document.getElementById("paginacionInfo").innerText = `Mostrando ${inicio}–${fin} de ${cotizacionesFiltradas.length}`;

    const btns = document.getElementById("paginacionBtns");
    let html = `<button class="page-btn" onclick="irPagina(${paginaActual-1})" ${paginaActual===1?"disabled":""}>← Anterior</button>`;

    const rango = 2;
    for (let i = 1; i <= totalPaginas; i++) {
      if (i === 1 || i === totalPaginas || (i >= paginaActual - rango && i <= paginaActual + rango)) {
        html += `<button class="page-btn ${i===paginaActual?"active":""}" onclick="irPagina(${i})">${i}</button>`;
      } else if (i === paginaActual - rango - 1 || i === paginaActual + rango + 1) {
        html += `<button class="page-btn" disabled>…</button>`;
      }
    }

    html += `<button class="page-btn" onclick="irPagina(${paginaActual+1})" ${paginaActual===totalPaginas?"disabled":""}>Siguiente →</button>`;
    btns.innerHTML = html;
  }

  function irPagina(p) {
    const totalPaginas = Math.ceil(cotizacionesFiltradas.length / POR_PAGINA);
    if (p < 1 || p > totalPaginas) return;
    paginaActual = p;
    renderTabla();
    window.scrollTo({ top: 0, behavior: "smooth" });
  }

  function verDetalle(cotizacionId) {
    const articulos = cotizacionesFiltradas.filter(c => c.CotizacionId === cotizacionId);
    if (!articulos.length) return;

    const primera = articulos[0];
    document.getElementById("modalTitulo").innerText = `Cotización #${primera.NumeroCotizacion || cotizacionId}`;
    document.getElementById("modalSubtitulo").innerText = formatFecha(primera.FechaCotizacion);

    // Info general
    document.getElementById("detalleGrid").innerHTML = `
      <div class="detalle-item"><label>Cliente</label><span>${primera.Cliente || "—"}</span></div>
      <div class="detalle-item"><label>Tipo de Cliente</label><span>${primera.TipoCliente || "—"}</span></div>
      <div class="detalle-item"><label>Vendedor</label><span>${primera.Vendedor || "—"}</span></div>
      <div class="detalle-item"><label>Forma de Pago</label><span>${primera.FormaPago || "—"}</span></div>
      <div class="detalle-item"><label>Tipo de Cambio</label><span>S/ ${Number(primera.TipoCambio || 0).toFixed(3)}</span></div>
      <div class="detalle-item"><label>Validez Oferta</label><span>${primera.TiempoValidezOferta || "—"}</span></div>
      ${primera.Comentarios ? `<div class="detalle-item" style="grid-column:1/-1"><label>Comentarios</label><span>${primera.Comentarios}</span></div>` : ""}
    `;

    // Artículos
    const moneda = primera.Moneda === "Dolares" ? "$" : "€";
    let totalVenta = 0;
    let totalUnitario = 0;

    document.getElementById("articulosBody").innerHTML = articulos.map(a => {
      const vu = Number(a.ValorUnitario) || 0;
      const vv = Number(a.ValorVenta) || 0;
      const desc = Number(a.PorcentajeDescuento) || 0;
      totalVenta += vv;
      totalUnitario += vu * (a.Cantidad || 1);
      const estado = a.Estado || "";
      let badgeClass = "badge-otro";
      if (estado.toLowerCase() === "atendido") badgeClass = "badge-atendido";
      else if (estado.toLowerCase() === "pendiente") badgeClass = "badge-pendiente";
      else if (estado.toLowerCase() === "perdido") badgeClass = "badge-perdido";

      return `<tr>
        <td class="mono">${a.CodigoArticulo || "—"}</td>
        <td>${a.Articulo || "—"}</td>
        <td style="text-align:center;">${a.Cantidad || 1}</td>
        <td>${a.Moneda || "—"}</td>
        <td style="text-align:right;">${moneda}${vu.toLocaleString("es-PE",{minimumFractionDigits:2,maximumFractionDigits:2})}</td>
        <td style="text-align:center;">${desc > 0 ? desc + "%" : "—"}</td>
        <td style="text-align:right;font-weight:700;">${moneda}${vv.toLocaleString("es-PE",{minimumFractionDigits:2,maximumFractionDigits:2})}</td>
        <td><span class="badge-estado ${badgeClass}">${estado || "—"}</span></td>
      </tr>`;
    }).join("");

    document.getElementById("totalRow").innerHTML = `
      <div class="total-item">
        <label>Subtotal</label>
        <span>${moneda}${totalUnitario.toLocaleString("es-PE",{minimumFractionDigits:2,maximumFractionDigits:2})}</span>
      </div>
      <div class="total-item highlight">
        <label>Total Venta</label>
        <span>${moneda}${totalVenta.toLocaleString("es-PE",{minimumFractionDigits:2,maximumFractionDigits:2})}</span>
      </div>
    `;

    document.getElementById("modalDetalle").classList.add("show");
  }

  function cerrarModal() {
    document.getElementById("modalDetalle").classList.remove("show");
  }

  function formatFecha(f) {
    if (!f) return "—";
    const d = new Date(f);
    if (isNaN(d)) return f;
    return d.toLocaleDateString("es-PE", { day: "2-digit", month: "2-digit", year: "numeric" });
  }

  // Buscar con Enter
  ["filtroCot","filtroCliente","filtroArticulo"].forEach(id => {
    document.getElementById(id).addEventListener("keydown", e => {
      if (e.key === "Enter") buscar();
    });
  });

  function toggleMenu() {
    document.getElementById("sidebar").classList.toggle("open");
    document.getElementById("overlay").classList.toggle("show");
  }
  function cerrarMenu() {
    document.getElementById("sidebar").classList.remove("open");
    document.getElementById("overlay").classList.remove("show");
  }

  async function logout() {
    localStorage.clear();
    window.location.href = "index.html";
  }

  // Iniciar
  cargarDatos();
</script>
</body>
</html>
