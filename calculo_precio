<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cotizaciones — 3R Ingeniería</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Segoe UI', sans-serif;
      background: #c8cdd6;
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: flex-start;
    }
    .container {
      display: flex;
      width: 100%;
      max-width: 1400px;
      min-height: 100vh;
      background: #fff;
      box-shadow: 0 0 60px rgba(0,0,0,0.15);
    }

    /* SIDEBAR */
    .sidebar {
      width: 240px; min-width: 240px;
      background: #1a1a1a;
      display: flex; flex-direction: column;
      padding: 32px 16px;
      position: sticky; top: 0; height: 100vh;
    }
    .sidebar-logo { text-align: center; margin-bottom: 20px; }
    .sidebar-logo img {
      width: 160px; height: auto;
      background: #fff; border-radius: 14px;
      padding: 12px; margin-bottom: 16px;
    }
    .sidebar-logo .line {
      width: 28px; height: 2px;
      background: #e02020; border-radius: 2px; margin: 0 auto 12px;
    }
    .sidebar-logo .tagline {
      color: #fff; font-size: 15px; font-weight: 700;
      letter-spacing: 1px; text-transform: uppercase; line-height: 2.5;
    }
    .nav-section {
      font-size: 9px; font-weight: 700; color: #444;
      letter-spacing: 1.5px; text-transform: uppercase;
      margin: 12px 0 8px; padding: 0 4px;
    }
    .nav-item {
      border-radius: 10px; padding: 10px 14px;
      display: flex; align-items: center; gap: 10px;
      margin-bottom: 2px; cursor: pointer; transition: background 0.15s;
    }
    .nav-item:hover { background: #2a2a2a; }
    .nav-item.active { background: #e02020; }
    .nav-item span { font-size: 12px; color: #888; font-weight: 500; }
    .nav-item.active span { color: #fff; font-weight: 700; }
    .sidebar-footer { margin-top: auto; border-top: 1px solid #2a2a2a; padding-top: 16px; }

    /* MAIN */
    .main {
      flex: 1; display: flex; flex-direction: column;
      background: #f7f8fa; min-width: 0; min-height: 100vh;
    }
    .topbar {
      background: #fff; padding: 16px 28px;
      display: flex; align-items: center; justify-content: space-between;
      border-bottom: 1px solid #f0f0f0;
      position: sticky; top: 0; z-index: 10;
    }
    .topbar-left h2 { font-size: 16px; font-weight: 700; color: #111; }
    .topbar-left p { font-size: 11px; color: #999; margin-top: 2px; }
    .topbar-right { display: flex; align-items: center; gap: 12px; }
    .version {
      background: #f5f5f5; border: 1px solid #eee;
      border-radius: 20px; padding: 3px 10px;
      font-size: 10px; color: #aaa; font-weight: 700; letter-spacing: 1px;
    }
    .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 4px; }
    .hamburger span { width: 22px; height: 2px; background: #111; border-radius: 2px; }

    /* CONTENT */
    .content { flex: 1; padding: 24px 28px; }

    /* SEARCH BAR */
    .search-bar {
      background: #fff; border-radius: 14px;
      padding: 20px; margin-bottom: 20px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
      border: 1.5px solid #e8e8e8;
    }
    .search-bar h3 {
      font-size: 12px; font-weight: 700; color: #aaa;
      letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 14px;
    }
    .search-inputs {
      display: grid; grid-template-columns: 1fr 1fr 1fr auto;
      gap: 12px; align-items: end;
    }
    .search-field label {
      display: block; font-size: 10px; font-weight: 700;
      color: #555; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 6px;
    }
    .search-field input {
      width: 100%; padding: 10px 12px;
      border: 1.5px solid #e8e8e8; border-radius: 10px;
      font-size: 13px; color: #111; background: #fafafa;
      outline: none; transition: all 0.2s;
    }
    .search-field input:focus {
      border-color: #e02020;
      box-shadow: 0 0 0 3px rgba(224,32,32,0.08);
      background: #fff;
    }
    .btn-search {
      padding: 10px 20px; background: #e02020;
      color: white; border: none; border-radius: 10px;
      font-size: 13px; font-weight: 700; cursor: pointer;
      transition: background 0.2s; white-space: nowrap;
      height: 40px; display: flex; align-items: center; gap: 6px;
    }
    .btn-search:hover { background: #c01a1a; }
    .btn-clear {
      padding: 10px 16px; background: transparent;
      color: #999; border: 1.5px solid #e8e8e8;
      border-radius: 10px; font-size: 13px; font-weight: 600;
      cursor: pointer; transition: all 0.2s; height: 40px;
    }
    .btn-clear:hover { border-color: #ccc; color: #666; }

    /* STATS ROW */
    .stats-row {
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 12px; margin-bottom: 20px;
    }
    .stat-mini {
      background: #fff; border: 1.5px solid #e8e8e8;
      border-radius: 12px; padding: 14px 16px;
    }
    .stat-mini .label { font-size: 10px; color: #aaa; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; }
    .stat-mini .value { font-size: 20px; font-weight: 700; color: #111; }
    .stat-mini .sub { font-size: 10px; color: #aaa; margin-top: 2px; }

    /* TABLE */
    .table-wrap {
      background: #fff; border-radius: 14px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
      border: 1.5px solid #e8e8e8; overflow: hidden;
    }
    .table-header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 16px 20px; border-bottom: 1px solid #f0f0f0;
    }
    .table-header h3 { font-size: 13px; font-weight: 700; color: #111; }
    .table-count {
      background: #fff0f0; color: #e02020;
      font-size: 10px; font-weight: 700; padding: 3px 10px;
      border-radius: 20px; letter-spacing: 0.5px;
    }
    .table-scroll { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 12px; }
    thead th {
      background: #f7f8fa; padding: 10px 14px;
      text-align: left; font-size: 10px; font-weight: 700;
      color: #888; letter-spacing: 1px; text-transform: uppercase;
      border-bottom: 1px solid #f0f0f0; white-space: nowrap;
    }
    tbody tr {
      border-bottom: 1px solid #f5f5f5;
      transition: background 0.1s; cursor: pointer;
    }
    tbody tr:hover { background: #fafafa; }
    tbody tr:last-child { border-bottom: none; }
    tbody td { padding: 11px 14px; color: #333; vertical-align: middle; }
    tbody td.mono { font-family: monospace; font-size: 11px; color: #666; }

    .badge-estado {
      display: inline-block; padding: 2px 8px;
      border-radius: 20px; font-size: 10px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.5px;
    }
    .badge-atendido { background: #e8f5e9; color: #2e7d32; }
    .badge-pendiente { background: #fff8e1; color: #f57f17; }
    .badge-perdido { background: #fde8e8; color: #c62828; }
    .badge-otro { background: #f5f5f5; color: #666; }

    .btn-ver {
      padding: 5px 12px; background: transparent;
      border: 1.5px solid #e02020; color: #e02020;
      border-radius: 8px; font-size: 11px; font-weight: 700;
      cursor: pointer; transition: all 0.2s;
    }
    .btn-ver:hover { background: #e02020; color: #fff; }

    /* LOADING / EMPTY */
    .loading-state {
      text-align: center; padding: 60px 20px; color: #bbb;
    }
    .loading-spinner {
      width: 28px; height: 28px;
      border: 3px solid #e8e8e8; border-top-color: #e02020;
      border-radius: 50%; animation: spin 0.8s linear infinite;
      margin: 0 auto 12px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .empty-state { text-align: center; padding: 60px 20px; }
    .empty-icon { font-size: 40px; margin-bottom: 12px; }
    .empty-state h4 { font-size: 14px; font-weight: 700; color: #333; margin-bottom: 6px; }
    .empty-state p { font-size: 12px; color: #aaa; }

    /* MODAL DETALLE */
    .modal-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,0.5); z-index: 200;
      justify-content: center; align-items: center; padding: 20px;
    }
    .modal-overlay.show { display: flex; }
    .modal-detalle {
      background: #fff; border-radius: 20px;
      width: 900px; max-width: 100%;
      max-height: 90vh; overflow-y: auto;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }
    .modal-top {
      background: #1a1a1a; border-radius: 20px 20px 0 0;
      padding: 20px 28px; display: flex;
      align-items: center; justify-content: space-between;
    }
    .modal-top h3 { font-size: 16px; font-weight: 700; color: #fff; }
    .modal-top span { font-size: 11px; color: #888; }
    .modal-close-btn {
      background: #2a2a2a; border: none; color: #aaa;
      width: 30px; height: 30px; border-radius: 8px;
      font-size: 14px; cursor: pointer; transition: background 0.2s;
      display: flex; align-items: center; justify-content: center;
    }
    .modal-close-btn:hover { background: #e02020; color: #fff; }
    .modal-body { padding: 24px 28px; }

    .detalle-grid {
      display: grid; grid-template-columns: repeat(3, 1fr);
      gap: 14px; margin-bottom: 24px;
    }
    .detalle-item { }
    .detalle-item label {
      display: block; font-size: 10px; font-weight: 700;
      color: #aaa; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 4px;
    }
    .detalle-item span { font-size: 13px; font-weight: 600; color: #111; }

    .detalle-section-title {
      font-size: 11px; font-weight: 700; color: #aaa;
      letter-spacing: 1.5px; text-transform: uppercase;
      margin-bottom: 12px; padding-bottom: 8px;
      border-bottom: 1px solid #f0f0f0;
    }
    .articulos-table { width: 100%; border-collapse: collapse; font-size: 12px; margin-bottom: 20px; }
    .articulos-table th {
      background: #f7f8fa; padding: 9px 12px;
      text-align: left; font-size: 10px; font-weight: 700;
      color: #888; letter-spacing: 1px; text-transform: uppercase;
      border-bottom: 1px solid #f0f0f0;
    }
    .articulos-table td {
      padding: 10px 12px; border-bottom: 1px solid #f5f5f5; color: #333;
    }
    .articulos-table tr:last-child td { border-bottom: none; }
    .total-row {
      display: flex; justify-content: flex-end; gap: 20px;
      background: #f7f8fa; border-radius: 10px; padding: 14px 20px;
    }
    .total-item label { font-size: 10px; color: #aaa; text-transform: uppercase; letter-spacing: 1px; display: block; margin-bottom: 2px; }
    .total-item span { font-size: 16px; font-weight: 700; color: #111; }
    .total-item.highlight span { color: #e02020; }

    /* PAGINACIÓN */
    .pagination {
      display: flex; align-items: center; justify-content: space-between;
      padding: 14px 20px; border-top: 1px solid #f0f0f0;
    }
    .pagination-info { font-size: 11px; color: #aaa; }
    .pagination-btns { display: flex; gap: 6px; }
    .page-btn {
      padding: 6px 12px; border: 1.5px solid #e8e8e8;
      border-radius: 8px; font-size: 12px; font-weight: 600;
      cursor: pointer; background: #fff; color: #555; transition: all 0.15s;
    }
    .page-btn:hover { border-color: #e02020; color: #e02020; }
    .page-btn.active { background: #e02020; border-color: #e02020; color: #fff; }
    .page-btn:disabled { opacity: 0.4; cursor: not-allowed; }

    .overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,0.5); z-index: 99;
    }
    .overlay.show { display: block; }

    @media (max-width: 900px) {
      .sidebar { position: fixed; left: -240px; top: 0; height: 100vh; z-index: 100; transition: left 0.25s; }
      .sidebar.open { left: 0; }
      .hamburger { display: flex; }
      .content { padding: 16px; }
      .search-inputs { grid-template-columns: 1fr; }
      .stats-row { grid-template-columns: 1fr 1fr; }
      .detalle-grid { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 500px) {
      .stats-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<div class="overlay" id="overlay" onclick="cerrarMenu()"></div>

<div class="container">
  <!-- SIDEBAR -->
  <div class="sidebar" id="sidebar">
    <div class="sidebar-logo">
      <img src="logo.png" alt="3R Ingeniería">
      <div class="line"></div>
      <div class="tagline">Sistema de<br>Gestión</div>
    </div>
    <div class="nav-section">Navegación</div>
    <div class="nav-item" onclick="window.location.href='menu_principal.html'">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      <span>Dashboard</span>
    </div>
    <div class="nav-item active">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="12" y2="14"/></svg>
      <span>Cotizaciones</span>
    </div>
    <div class="sidebar-footer">
      <div class="nav-item" onclick="logout()">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#e02020" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        <span style="color:#e02020;">Cerrar sesión</span>
      </div>
    </div>
  </div>

  <!-- MAIN -->
  <div class="main">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:14px;">
        <div class="hamburger" onclick="toggleMenu()">
          <span></span><span></span><span></span>
        </div>
        <div class="topbar-left">
          <h2>Cotizaciones</h2>
          <p id="topbarFecha"></p>
        </div>
      </div>
      <div class="topbar-right">
        <span class="version">V 1.0</span>
      </div>
    </div>

    <div class="content">

      <!-- BUSCADOR -->
      <div class="search-bar">
        <h3>Buscar cotización</h3>
        <div class="search-inputs">
          <div class="search-field">
            <label>N° Cotización</label>
            <input type="text" id="filtroCot" placeholder="Ej: 00022">
          </div>
          <div class="search-field">
            <label>Cliente</label>
            <input type="text" id="filtroCliente" placeholder="Nombre del cliente...">
          </div>
          <div class="search-field">
            <label>Artículo</label>
            <input type="text" id="filtroArticulo" placeholder="Nombre o código...">
          </div>
          <div style="display:flex;gap:8px;align-items:end;">
            <button class="btn-search" onclick="buscar()">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              Buscar
            </button>
            <button class="btn-clear" onclick="limpiar()">Limpiar</button>
          </div>
        </div>
      </div>

      <!-- STATS -->
      <div class="stats-row">
        <div class="stat-mini">
          <div class="label">Total encontradas</div>
          <div class="value" id="statTotal">—</div>
          <div class="sub">cotizaciones</div>
        </div>
        <div class="stat-mini">
          <div class="label">Atendidas</div>
          <div class="value" id="statAtendidas">—</div>
          <div class="sub">registros</div>
        </div>
        <div class="stat-mini">
          <div class="label">Valor total USD</div>
          <div class="value" id="statValor">—</div>
          <div class="sub">suma filtrada</div>
        </div>
        <div class="stat-mini">
          <div class="label">Clientes únicos</div>
          <div class="value" id="statClientes">—</div>
          <div class="sub">en resultados</div>
        </div>
      </div>

      <!-- TABLA -->
      <div class="table-wrap">
        <div class="table-header">
          <h3>Resultados</h3>
          <span class="table-count" id="tableCount">0 registros</span>
        </div>
        <div class="table-scroll">
          <table id="tablaCotizaciones">
            <thead>
              <tr>
                <th>N° Cot.</th>
                <th>Fecha</th>
                <th>Cliente</th>
                <th>Artículo</th>
                <th>Cant.</th>
                <th>Moneda</th>
                <th>V. Unitario</th>
                <th>Descuento</th>
                <th>V. Venta</th>
                <th>Estado</th>
                <th>Vendedor</th>
                <th></th>
              </tr>
            </thead>
            <tbody id="tablaBody">
              <tr>
                <td colspan="12">
                  <div class="loading-state">
                    <div class="empty-icon">📋</div>
                    <h4>Ingresa un criterio de búsqueda</h4>
                    <p>Busca por número de cotización, cliente o artículo</p>
